# Database
# Local PostgreSQL example:
# DATABASE_URL=postgresql://furniture_user:furniture_password@localhost:5432/furniture_db
# DIRECT_URL=postgresql://furniture_user:furniture_password@localhost:5432/furniture_db
# Supabase examples for Render:
# DATABASE_URL uses the pooled connection for runtime traffic.
# DIRECT_URL uses the direct/non-pooling connection for Prisma migrations.
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# DIRECT_URL=postgres://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
DIRECT_URL=
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Server
PORT=3000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5173

# JWT (cho admin authentication)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=furniture

# Email (optional - cho notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
