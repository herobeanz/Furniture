# Database
# Local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/furniture_db
# DIRECT_URL=postgresql://user:password@localhost:5432/furniture_db

# Supabase (Render + cloud dev) — project ref bdsgmnmcinlubhowzbna
# Dashboard → Connect → Prisma (hoặc .env với prefix furniture_)
# DATABASE_URL = POSTGRES_PRISMA_URL — transaction pooler :6543 + pgbouncer=true
# DATABASE_URL=postgres://postgres.bdsgmnmcinlubhowzbna:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# DIRECT_URL = POSTGRES_URL_NON_POOLING — session pooler :5432 (KHÔNG dùng db.<ref>.supabase.co trên Render)
# DIRECT_URL=postgres://postgres.bdsgmnmcinlubhowzbna:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=
DIRECT_URL=

# Server
PORT=3000
NODE_ENV=development

# CORS — Render production:
# FRONTEND_URL=https://dogohungcuong.vercel.app
# Local + production:
# FRONTEND_URL=https://dogohungcuong.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# JWT (cho admin authentication)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Upload (Cloudinary)
MAX_FILE_SIZE=5242880
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=furniture
