# =============================================================================
# Cấu trúc env backend (NestJS + Prisma)
# =============================================================================
# .env                 — secrets local (gitignore): DB, JWT, Cloudinary
# .env.development     — mặc định dev (đã commit): PORT, CORS, NODE_ENV
# Production (Render)  — xem be/.env.production.example, set trên Render Dashboard
# .env.local           — override cá nhân (gitignore, ưu tiên cao nhất)
# =============================================================================

# --- .env (development — PostgreSQL local) ---

# Database — PostgreSQL trên máy dev (KHÔNG dùng Supabase ở local)
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/noithat?schema=public
DIRECT_URL=postgresql://postgres:<password>@localhost:5432/noithat?schema=public

# JWT (admin) — đổi secret khác với production
JWT_SECRET=your-dev-secret-change-me
JWT_EXPIRES_IN=7d

# Upload (Cloudinary)
MAX_FILE_SIZE=5242880
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=furniture

# --- Dev server / CORS: xem be/.env.development ---
# --- Production Supabase: xem be/.env.production.example (Render Dashboard) ---
