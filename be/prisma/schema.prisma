// Prisma schema - Furniture E-commerce
// Updated structure: Room > Category > Product

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AdminRole {
  admin
  editor
}

enum InquirySource {
  product
  contact
  facebook
  zalo
}

enum InquiryStatus {
  new
  contacted
  done
}

enum ProductStatus {
  available
  hidden
  discontinued
}

// ---------------------------------------------------------------------------
// Admins
// ---------------------------------------------------------------------------

model Admin {
  id            Int       @id @default(autoincrement())
  username      String?   @unique
  email         String    @unique
  passwordhashed String   @map("passwordhashed")
  fullname      String?   @map("fullname")
  role          AdminRole @default(admin)
  is_active     Boolean   @default(true) @map("is_active")
  last_login_at DateTime? @map("last_login_at")
  created_at    DateTime  @default(now()) @map("created_at")
  updated_at    DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

// ---------------------------------------------------------------------------
// Rooms (Hero/Phòng - Level 1: Phòng khách, Phòng ngủ, Phòng bếp...)
// ---------------------------------------------------------------------------

model Room {
  id              Int         @id @default(autoincrement())
  name            String
  slug            String       @unique
  description     String?      @db.Text
  thumbnail       String?
  order_index     Int          @default(0) @map("order_index")
  is_active       Boolean      @default(true) @map("is_active")
  seo_title       String?      @db.Text @map("seo_title")
  seo_description String?      @db.Text @map("seo_description")
  created_at      DateTime     @default(now()) @map("created_at")
  updated_at      DateTime     @updatedAt @map("updated_at")

  categories      Category[]

  @@index([slug])
  @@index([order_index])
  @@map("rooms")
}

// ---------------------------------------------------------------------------
// Categories (Level 2: Sofa, Giường, Tủ, Bàn, Ghế...)
// ---------------------------------------------------------------------------

model Category {
  id              Int           @id @default(autoincrement())
  room_id         Int           @map("room_id")
  name            String
  slug            String
  description     String?       @db.Text
  thumbnail       String?
  order_index     Int           @default(0) @map("order_index")
  is_active       Boolean       @default(true) @map("is_active")
  seo_title       String?       @db.Text @map("seo_title")
  seo_description String?       @db.Text @map("seo_description")
  created_at      DateTime      @default(now()) @map("created_at")
  updated_at      DateTime      @updatedAt @map("updated_at")

  room            Room          @relation(fields: [room_id], references: [id], onDelete: Cascade)
  products        Product[]

  @@unique([room_id, slug])
  @@index([slug])
  @@index([room_id])
  @@index([order_index])
  @@map("categories")
}

// ---------------------------------------------------------------------------
// Products (Level 3)
// ---------------------------------------------------------------------------

model Product {
  id                Int            @id @default(autoincrement())
  category_id       Int            @map("category_id")
  name              String
  slug              String         @unique
  sku               String
  short_description String?        @db.Text @map("short_description")
  description       String?        @db.Text
  price             Decimal         @db.Decimal(10, 2)
  sale_price        Decimal?       @db.Decimal(10, 2) @map("sale_price")
  thumbnail         String?
  status            ProductStatus  @default(available)
  material          String?
  dimensions        String?
  color             String?
  warranty          String?
  /// Nếu true, hiển thị "Liên hệ" thay vì giá số trên frontend
  is_contact_price  Boolean        @default(false) @map("is_contact_price")
  sold_count        Int            @default(0) @map("sold_count")
  rating            Decimal?       @db.Decimal(2, 1) @map("rating")
  is_active         Boolean        @default(true) @map("is_active")
  is_featured       Boolean        @default(false) @map("is_featured")
  is_hot            Boolean        @default(false) @map("is_hot")
  is_daily_flash_sale Boolean      @default(false) @map("is_daily_flash_sale")
  flash_sale_end_at  DateTime?     @map("flash_sale_end_at")
  seo_title         String?        @db.Text @map("seo_title")
  seo_description   String?        @db.Text @map("seo_description")
  created_at        DateTime       @default(now()) @map("created_at")
  updated_at        DateTime       @updatedAt @map("updated_at")

  category          Category       @relation(fields: [category_id], references: [id], onDelete: Cascade)
  images            ProductImage[]
  inquiries         Inquiry[]
  collectionProducts CollectionProduct[]

  @@index([slug])
  @@index([category_id])
  @@index([status])
  @@index([sku])
  @@index([price])
  @@index([is_featured])
  @@index([is_hot])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Product Images
// ---------------------------------------------------------------------------

model ProductImage {
  id         Int      @id @default(autoincrement())
  product_id Int      @map("product_id")
  image_url  String   @map("image_url")
  is_primary Boolean  @default(false) @map("is_primary")
  alt_text   String?  @map("alt_text")
  order_index Int     @default(0) @map("order_index")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([is_primary])
  @@map("product_images")
}

// ---------------------------------------------------------------------------
// Collections
// ---------------------------------------------------------------------------

model Collection {
  id              Int                  @id @default(autoincrement())
  name            String
  slug            String               @unique
  description     String?              @db.Text
  thumbnail       String?
  order_index     Int                  @default(0) @map("order_index")
  is_active       Boolean              @default(true) @map("is_active")
  seo_title       String?              @db.Text @map("seo_title")
  seo_description String?              @db.Text @map("seo_description")
  created_at      DateTime             @default(now()) @map("created_at")
  updated_at      DateTime             @updatedAt @map("updated_at")

  products        CollectionProduct[]

  @@index([slug])
  @@index([order_index])
  @@map("collections")
}

// ---------------------------------------------------------------------------
// Collection Products (Many-to-Many)
// ---------------------------------------------------------------------------

model CollectionProduct {
  collection_id Int       @map("collection_id")
  product_id    Int       @map("product_id")
  order_index   Int       @default(0) @map("order_index")
  created_at    DateTime  @default(now()) @map("created_at")

  collection    Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([collection_id, product_id])
  @@index([collection_id])
  @@index([product_id])
  @@map("collection_products")
}

// ---------------------------------------------------------------------------
// Inquiries (customer leads)
// ---------------------------------------------------------------------------

model Inquiry {
  id           Int            @id @default(autoincrement())
  product_id   Int?           @map("product_id")
  name         String
  phone        String
  email        String?
  message      String         @db.Text
  source       InquirySource
  status       InquiryStatus  @default(new)
  admin_notes  String?        @db.Text @map("admin_notes")
  responded_at DateTime?      @map("responded_at")
  created_at   DateTime       @default(now()) @map("created_at")
  updated_at   DateTime       @updatedAt @map("updated_at")

  product      Product?       @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([product_id])
  @@index([source])
  @@map("inquiries")
}

// ---------------------------------------------------------------------------
// CMS Pages (About, Privacy, Terms, etc.)
// ---------------------------------------------------------------------------

model CmsPage {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  content         String    @db.Text
  thumbnail       String?
  seo_title       String?   @map("seo_title")
  seo_description String?   @db.Text @map("seo_description")
  page_type       String?   @map("page_type")
  is_active       Boolean   @default(true) @map("is_active")
  meta_keywords   String?   @map("meta_keywords")
  published_at    DateTime? @map("published_at")
  created_at      DateTime  @default(now()) @map("created_at")
  updated_at      DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([is_active])
  @@index([page_type])
  @@map("cms_pages")
}

// ---------------------------------------------------------------------------
// Blog Posts
// ---------------------------------------------------------------------------

model BlogPost {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  excerpt         String?   @db.Text
  content         String    @db.Text
  thumbnail       String?
  category        String?
  author          String?
  seo_title       String?   @map("seo_title")
  seo_description String?   @db.Text @map("seo_description")
  is_active       Boolean   @default(true) @map("is_active")
  is_featured     Boolean   @default(false) @map("is_featured")
  published_at    DateTime? @map("published_at")
  created_at      DateTime  @default(now()) @map("created_at")
  updated_at      DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([is_active])
  @@index([is_featured])
  @@index([published_at])
  @@index([category])
  @@map("blog_posts")
}
