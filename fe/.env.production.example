# Production — copy sang Vercel → Project Settings → Environment Variables
# (file `.env.production` local bị gitignore; trên Vercel set trực tiếp trên dashboard)

VITE_API_BASE_URL=https://your-backend-host.example.com/api/v1
VITE_APP_URL=https://your-frontend.vercel.app
VITE_APP_NAME=Tên thương hiệu

# Brand / liên hệ / MXH — copy từ fe/.env hoặc set trên Vercel (nếu không set, dùng DEFAULTS trong fe/src/constants/site.ts)
# VITE_FACEBOOK_URL=https://www.facebook.com/your-page
# VITE_TIKTOK_URL=https://www.tiktok.com/@your-account
# VITE_YOUTUBE_URL=https://www.youtube.com/@your-channel

# Supabase (nếu dùng) — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
