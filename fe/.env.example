# =============================================================================
# Cấu trúc env frontend (Vite)
# =============================================================================
# .env                 — giá trị chung (brand, liên hệ, MXH) → copy thành .env
# .env.development     — URL local (đã commit, dùng khi `yarn dev`)
# .env.production      — production local preview (gitignore) hoặc set trên Vercel
# .env.production.example — mẫu biến production cho Vercel
# .env.local           — override cá nhân (gitignore, ưu tiên cao nhất)
# =============================================================================

# --- .env (chung dev + prod) — cp .env.example .env rồi điền phần dưới ---

# Thương hiệu (fe/src/constants/site.ts)
VITE_BRAND_NAME=Tên thương hiệu
# Logo mark (mặc định HC.jpg / favicon HC.svg trong fe/src/assets)
# VITE_BRAND_LOGO_URL=https://example.com/logo.png
VITE_BRAND_LOGO_LINE_SM=DÒNG PHỤ LOGO
VITE_BRAND_LOGO_LINE_LG=TÊN THƯƠNG HIỆU
VITE_BRAND_FOOTER_TITLE=TÊN THƯƠNG HIỆU
VITE_BRAND_TAGLINE=Mô tả ngắn về thương hiệu và sản phẩm.

# Liên hệ
VITE_CONTACT_PHONE=+84xxxxxxxxx
VITE_CONTACT_EMAIL=contact@example.com
VITE_CONTACT_ADDRESS_LINE1=Địa chỉ dòng 1,
VITE_CONTACT_ADDRESS_LINE2=Quận/Huyện, Thành phố
VITE_CONTACT_MAP_URL=https://maps.google.com/?q=lat,lng
VITE_CONTACT_MAP_LAT=21.000000
VITE_CONTACT_MAP_LNG=105.000000
VITE_CONTACT_HOURS_SHORT=08:00 - 17:30 (T2 - T7)
VITE_CONTACT_HOURS_LINE1=08:00 - 17:30
VITE_CONTACT_HOURS_LINE2=Thứ 2 - Thứ 7

# Mạng xã hội
VITE_FACEBOOK_URL=https://www.facebook.com/your-page
VITE_MESSENGER_URL=https://m.me/your-page
VITE_ZALO_URL=https://zalo.me/your-number
VITE_TIKTOK_URL=https://www.tiktok.com/@your-account
# VITE_INSTAGRAM_URL=https://www.instagram.com/your-account
# VITE_YOUTUBE_URL=https://www.youtube.com/@your-channel

# Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_PLAUSIBLE_DOMAIN=your-domain.com

# --- Dev URLs: xem fe/.env.development (tự load khi yarn dev) ---
# --- Prod URLs: xem fe/.env.production.example (set trên Vercel) ---
